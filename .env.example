# Copy to .env and fill in real values. .env is gitignored — never commit
# actual secrets (AD-5).

ENVIRONMENT=development

# --- PostgreSQL ---
# POSTGRES_HOST: "localhost" for host-based dev against the compose Postgres
# published on 127.0.0.1; docker-compose.yml overrides this to "postgres"
# (the service name) for the api/scheduler containers.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=growthtrack

# Migration-capable (DDL) role — used by Alembic only.
POSTGRES_MIGRATOR_USER=growthtrack_migrator
POSTGRES_MIGRATOR_PASSWORD=change-me

# Runtime DML-only role — used by the api/scheduler containers.
POSTGRES_APP_USER=growthtrack_app
POSTGRES_APP_PASSWORD=change-me

# Read-only role — used by the backup service only (SELECT only, no DDL/DML).
POSTGRES_BACKUP_USER=growthtrack_backup
POSTGRES_BACKUP_PASSWORD=change-me

# --- Auth ---
# Signing key for issued JWTs. Generate with: openssl rand -hex 32
JWT_SIGNING_KEY=change-me
# How long an issued session stays valid before re-login is required.
# Optional; defaults to 480 (8 hours) if unset.
JWT_EXPIRY_MINUTES=480
# Failed login attempts before an account is temporarily locked out.
# Optional; defaults to 5 if unset.
LOGIN_LOCKOUT_THRESHOLD=5
# How long an account stays locked out after too many failed attempts.
# Optional; defaults to 15 if unset.
LOGIN_LOCKOUT_DURATION_MINUTES=15
# How long a password reset link stays valid before it expires.
# Optional; defaults to 60 if unset.
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=change-me
TWILIO_AUTH_TOKEN=change-me
TWILIO_WHATSAPP_NUMBER=change-me

# Exact public origin registered as this app's Twilio status-callback URL
# (must match the Twilio console exactly — a mismatch silently breaks
# signature verification for every delivery-status callback).
WEBHOOK_PUBLIC_BASE_URL=https://change-me.example.com
# Additional automatic retry attempts for a failed send, with exponential
# backoff (minutes). Optional; defaults shown. [ASSUMPTION — CONFIRM, PRD
# §13.12] pending confirmation with a business stakeholder. Max 3 (backend
# only has three backoff tiers configured below). Setting this to 0 is a
# distinct operating mode: every failure is immediately terminal, no retry.
NOTIFICATION_MAX_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_BACKOFF_MINUTES_1=1
NOTIFICATION_RETRY_BACKOFF_MINUTES_2=5
NOTIFICATION_RETRY_BACKOFF_MINUTES_3=15
# How often the scheduler polls for retry-eligible deliveries. Optional;
# defaults to 30 if unset.
NOTIFICATION_RETRY_POLL_INTERVAL_SECONDS=30

# --- Source System ingestion ---
# Directory the nightly import job reads sales_data.csv/brand_performance.csv/
# doctors.csv from. Optional; defaults to /data/source_system/incoming if
# unset. [ASSUMPTION — CONFIRM] Placeholder Phase-1 transport (PRD §13 Open
# Question #1) — pending confirmation with the business/ops stakeholder.
SOURCE_SYSTEM_IMPORT_DIR=/data/source_system/incoming
# UTC hour/minute the nightly import job runs at. Optional; default to
# 19:30 UTC (01:30 Asia/Dhaka) if unset. [ASSUMPTION — CONFIRM] placeholder
# trigger time — pending confirmation with a business stakeholder.
NIGHTLY_IMPORT_CRON_HOUR=19
NIGHTLY_IMPORT_CRON_MINUTE=30
# How often the scheduler polls for whether the DB-backed ReportSchedule's
# (Story 4.4, Administrator-editable via Settings) target send time has
# arrived. Optional; defaults to 60 if unset. Also the worst-case delay
# between the configured send time and the actual dispatch — raising this
# delays the Daily Report by up to that many seconds. Max 3600 (1 hour).
REPORT_SCHEDULE_POLL_INTERVAL_SECONDS=60
# Number of Doctors listed per Territory in the Daily Report. Optional;
# defaults to 5 if unset. [ASSUMPTION — CONFIRM] no source document
# specifies this count — pending confirmation with a business stakeholder.
REPORT_TOP_DOCTORS_N=5
